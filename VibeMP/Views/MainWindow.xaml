                  RenderOptions.BitmapScalingMode="HighQuality"
                >
                  <Image.Clip>
                    <RectangleGeometry Rect="0,0,56,56" RadiusX="6" RadiusY="6" />
                  </Image.Clip>
                </Image>
              </Border>
              <StackPanel VerticalAlignment="Center">
                <TextBlock
                  Text="{Binding Playback.SelectedTrack.Title, TargetNullValue='No track playing'}"
                  Foreground="White"
                  FontSize="14"
                  FontWeight="SemiBold"
                  TextTrimming="CharacterEllipsis"
                  Margin="0,0,0,4"
                />
                <TextBlock
                  Text="{Binding Playback.SelectedTrack.Artist, TargetNullValue='--'}"
                  Foreground="#A7A7A7"
                  FontSize="12"
                  TextTrimming="CharacterEllipsis"
                />
              </StackPanel>
            </StackPanel>

            <StackPanel
              Grid.Column="1"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Width="400"
            >
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                <Button
                  Command="{Binding ToggleShuffleCommand}"
                  Background="Transparent"
                  BorderThickness="0"
                  Width="32"
                  Height="32"
                  Margin="0,0,16,0"
                  Cursor="Hand"
                >
                  <Button.Template>
                    <ControlTemplate TargetType="Button">
                      <Border
                        x:Name="BgBorder"
                        Background="{TemplateBinding Background}"
                        CornerRadius="16"
                      >
                        <Path
                          x:Name="IconPath"
                          Data="M14.83,13.41L13.42,14.82L16.55,17.95L14.5,20H20V14.5L17.96,16.54L14.83,13.41M14.5,4L16.54,6.04L4,18.59L5.41,20L17.96,7.46L20,9.5V4M10.59,9.17L5.41,4L4,5.41L9.17,10.58L10.59,9.17Z"
                          Fill="#A7A7A7"
                          Width="14"
                          Height="14"
                          Stretch="Fill"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                        />
                      </Border>
                      <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter TargetName="BgBorder" Property="Background" Value="#282828" />
                          <Setter TargetName="IconPath" Property="Fill" Value="White" />
                        </Trigger>
                        <DataTrigger Binding="{Binding Playback.IsShuffleEnabled}" Value="True">
                          <Setter TargetName="IconPath" Property="Fill" Value="White" />
                        </DataTrigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Button.Template>
                </Button>
                <Button
                  Command="{Binding PlayPreviousTrackCommand}"
                  Background="Transparent"
                  BorderThickness="0"
                  Width="32"
                  Height="32"
                  Margin="0,0,16,0"
                  Cursor="Hand"
                >
                  <Button.Template>
                    <ControlTemplate TargetType="Button">
                      <Border
                        x:Name="BgBorder"
                        Background="{TemplateBinding Background}"
                        CornerRadius="16"
                      >
                        <Path
                          x:Name="IconPath"
                          Data="M6,18V6H8V18H6M9.5,12L18,6V18L9.5,12Z"
                          Fill="#A7A7A7"
                          Width="14"
                          Height="14"
                          Stretch="Fill"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                        />
                      </Border>
                      <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter TargetName="BgBorder" Property="Background" Value="#282828" />
                          <Setter TargetName="IconPath" Property="Fill" Value="White" />
                        </Trigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Button.Template>
                </Button>

                <Button
                  Command="{Binding TogglePlaybackCommand}"
                  Background="White"
                  BorderThickness="0"
                  Width="32"
                  Height="32"
                  Cursor="Hand"
                >
                  <Button.Template>
                    <ControlTemplate TargetType="Button">
                      <Border Background="{TemplateBinding Background}" CornerRadius="16">
                        <Path
                          x:Name="PlayIcon"
                          Data="M8,5.14V19.14L19,12.14L8,5.14Z"
                          Fill="Black"
                          Width="12"
                          Height="12"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Margin="2,0,0,0"
                          Stretch="Fill"
                        />
                      </Border>
                      <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding Playback.IsPlaying}" Value="True">
                          <Setter
                            TargetName="PlayIcon"
                            Property="Data"
                            Value="M14,19H18V5H14M6,19H10V5H6V19Z"
                          />
                          <Setter TargetName="PlayIcon" Property="Margin" Value="0" />
                        </DataTrigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Button.Template>
                </Button>

                <Button
                  Command="{Binding PlayNextTrackCommand}"
                  Background="Transparent"
                  BorderThickness="0"
                  Width="32"
                  Height="32"
                  Margin="16,0,0,0"
                  Cursor="Hand"
                >
                  <Button.Template>
                    <ControlTemplate TargetType="Button">
                      <Border
                        x:Name="BgBorder"
                        Background="{TemplateBinding Background}"
                        CornerRadius="16"
                      >
                        <Path
                          x:Name="IconPath"
                          Data="M16,18V6H18V18H16M5,6L13.5,12L5,18V6Z"
                          Fill="#A7A7A7"
                          Width="14"
                          Height="14"
                          Stretch="Fill"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
