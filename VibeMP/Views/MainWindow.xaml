                          <ContentPresenter
                            TextBlock.Foreground="White"
                            VerticalAlignment="Center"
                          />
                        </Border>
                      </ControlTemplate>
                    </Setter.Value>
                  </Setter>
                </Style>
              </DataGrid.Resources>

              <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                  <EventSetter Event="PreviewMouseLeftButtonDown" Handler="TrackRow_MouseClick" />
