                                        <Image
                                          Source="{Binding AlbumArt, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                                          Stretch="UniformToFill"
                                          RenderOptions.BitmapScalingMode="HighQuality"
                                        >
                                          <Image.Clip>
                                            <RectangleGeometry
                                              Rect="0,0,140,140"
                                              RadiusX="6"
                                              RadiusY="6"
                                            />
                                          </Image.Clip>
                                        </Image>
                                      </Border>

                                      <Border
