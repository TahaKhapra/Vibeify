<Window
  x:Class="VibeMP.Views.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:vms="clr-namespace:VibeMP.ViewModels"
  mc:Ignorable="d"
  Title="Vibeify"
  Height="620"
  Width="950"
  Background="#181818"
  WindowStartupLocation="CenterScreen"
  AllowDrop="True"
  Drop="Window_Drop"
>
  <Window.DataContext>
    <vms:MainViewModel />
  </Window.DataContext>

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />

    <Style x:Key="InverseVisibilityStyle" TargetType="FrameworkElement">
      <Setter Property="Visibility" Value="Collapsed" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsOnboarded}" Value="False">
          <Setter Property="Visibility" Value="Visible" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="CircleBpmButton" TargetType="Button">
      <Setter Property="Background" Value="#2D2D2D" />
      <Setter Property="Foreground" Value="#AAAAAA" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Width" Value="24" />
      <Setter Property="Height" Value="24" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="12">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="InlineTextBox" TargetType="TextBox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CaretBrush" Value="White" />
      <Setter Property="SelectionBrush" Value="#555555" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="Validation.ErrorTemplate" Value="{x:Null}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border Background="{TemplateBinding Background}">
              <ScrollViewer x:Name="PART_ContentHost" Focusable="false" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid Margin="20" Visibility="{Binding IsOnboarded, Converter={StaticResource BoolToVis}}">
      <TextBlock
        Text="Main Music Player Workspace Active"
        Foreground="White"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
      />
    </Grid>

    <Grid x:Name="OnboardingView" Style="{StaticResource InverseVisibilityStyle}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <StackPanel
        Grid.Row="0"
        Orientation="Horizontal"
        HorizontalAlignment="Center"
        Margin="0,50,0,0"
      >
        <Viewbox Width="54" Height="42" Margin="0,0,16,0">
          <Canvas Width="130" Height="103">
            <Path
              Fill="White"
              Data="M81.2334 0C108.149 0.000156743 129.973 21.8251 129.973 48.7402V86.6484C129.973 95.6382 122.716 102.895 113.727 102.896H97.4795V59.5713H119.142V48.7402C119.142 27.7822 102.191 10.8312 81.2334 10.8311C60.2753 10.8311 46.0322 27.7821 46.0322 48.7402V81.2334L46.0234 81.7412C45.6453 92.4003 33.4611 102.896 21.6621 102.896C9.67583 102.895 0.000151912 93.2196 0 81.2334C0 69.247 9.67574 59.5713 21.6621 59.5713C23.5921 59.5713 28.8905 59.5724 32.4932 60.7783V48.7402C32.4932 21.825 54.3182 0 81.2334 0ZM108.311 92.0645H113.727C116.705 92.0643 119.142 89.6269 119.142 86.6484V70.4023H108.311V92.0645ZM21.6621 74.0127C17.6907 74.0127 14.4414 77.262 14.4414 81.2334C14.4416 85.2046 17.6908 88.4541 21.6621 88.4541C25.6334 88.4541 28.8827 85.2047 28.8828 81.2334C28.8828 77.262 25.6335 74.0127 21.6621 74.0127Z M86.6484 97.4795H81.2334V59.5713H86.6484V97.4795Z M73.1094 92.0645H67.6943V64.9863H73.1094V92.0645Z M59.5713 62.2783V83.9404H54.1553V62.2783H59.5713Z"
            />
          </Canvas>
        </Viewbox>
        <TextBlock
          Text="Vibeify"
          Foreground="White"
          FontSize="36"
          FontFamily="{StaticResource LexendDeca}"
          FontWeight="Bold"
          VerticalAlignment="Center"
        />
      </StackPanel>

      <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,40">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="320" />
          <ColumnDefinition Width="80" />
          <ColumnDefinition Width="340" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Height="240">
          <Grid Cursor="Hand" MouseLeftButtonDown="SelectFolder_Click">
            <Grid.Style>
              <Style TargetType="Grid">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding PendingImportPaths.Count}" Value="0">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Grid.Style>

            <Rectangle
              Stroke="#333333"
              StrokeThickness="2"
              StrokeDashArray="4 4"
              RadiusX="12"
              RadiusY="12"
              Fill="#1C1C1C"
            />
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
              <Path
                Data="M4 4H10L12 6H20V18H4V4Z"
                Stroke="#555555"
                StrokeThickness="2"
                Fill="Transparent"
                Width="42"
                Height="36"
                Stretch="Fill"
                Margin="0,0,0,16"
                HorizontalAlignment="Center"
              />
              <TextBlock
                Text="Connect your music library&#x0a;to get started"
                TextAlignment="Center"
                Foreground="#777777"
                FontSize="15"
                FontFamily="{StaticResource LexendDeca}"
                FontWeight="Medium"
                LineHeight="22"
              />
              <TextBlock
                Text="{Binding StatusText}"
                Foreground="#666666"
                FontWeight="Bold"
                FontSize="11"
                Margin="0,12,0,4"
                MaxWidth="260"
                TextTrimming="CharacterEllipsis"
                HorizontalAlignment="Center"
              />
              <ProgressBar
                Value="{Binding ScanProgressValue}"
                Maximum="{Binding ScanProgressMax}"
                Width="220"
                Height="4"
                Background="#111111"
                Foreground="#888888"
                Visibility="{Binding ScanProgressValue, Converter={StaticResource BoolToVis}}"
              />
            </StackPanel>
          </Grid>

          <Grid AllowDrop="True" Drop="Window_Drop">
            <Grid.Style>
              <Style TargetType="Grid">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding HasPendingImports}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Grid.Style>

            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Button
              Grid.Row="0"
              Command="{Binding AddFilesCommand}"
              HorizontalContentAlignment="Stretch"
              Cursor="Hand"
              Margin="0,0,0,10"
            >
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border
                    Background="#1C1C1C"
                    BorderBrush="#333333"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10,8"
                  >
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                      <TextBlock
                        Text="+"
                        Foreground="#FFFFFF"
                        FontWeight="Bold"
                        FontSize="14"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                      />
                      <TextBlock
                        Text="Drop more folders or click here to append"
                        Foreground="#999999"
                        FontSize="12"
                        FontFamily="{StaticResource LexendDeca}"
                        VerticalAlignment="Center"
                      />
                    </StackPanel>
                  </Border>
                </ControlTemplate>
              </Button.Template>
            </Button>

            <Border
              Grid.Row="1"
              Background="#141414"
              CornerRadius="6"
              BorderBrush="#222222"
              BorderThickness="1"
            >
              <ListBox
                ItemsSource="{Binding PendingImportPaths}"
                Background="Transparent"
                BorderThickness="0"
                Padding="5"
              >
                <ListBox.Resources>
                  <SolidColorBrush
                    x:Key="{x:Static SystemColors.HighlightBrushKey}"
                    Color="#252525"
                  />
                  <SolidColorBrush
                    x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
                    Color="#1A1A1A"
                  />
                </ListBox.Resources>
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <Grid Margin="4,3">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>

                      <Path
                        Grid.Column="0"
                        Data="M21,3V15.5A3.5,3.5 0 0,1 17.5,19A3.5,3.5 0 0,1 14,15.5A3.5,3.5 0 0,1 17.5,12C18.04,12 18.55,12.12 19,12.34V6.47L9,8.6V17.5A3.5,3.5 0 0,1 5.5,21A3.5,3.5 0 0,1 2,17.5A3.5,3.5 0 0,1 5.5,14C6.04,14 6.55,14.12 7,14.34V6L21,3Z"
                        Fill="#FFFFFF"
                        Width="12"
                        Height="12"
                        Margin="0,0,8,0"
                        Stretch="Fill"
                        VerticalAlignment="Center"
                      />

                      <TextBlock
                        Grid.Column="1"
                        Text="{Binding DisplayName}"
                        Foreground="#CCCCCC"
                        FontSize="11"
                        FontFamily="{StaticResource LexendDeca}"
                        TextTrimming="CharacterEllipsis"
                        ToolTip="{Binding FullPath}"
                      />
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Border>
          </Grid>
        </Grid>

        <StackPanel Grid.Column="2" VerticalAlignment="Center">
          <Grid Margin="0,0,0,16">
            <TextBlock
              Text="Genres"
              Foreground="#888888"
              FontSize="15"
              FontFamily="{StaticResource LexendDeca}"
              FontWeight="Bold"
              HorizontalAlignment="Left"
              Margin="10,0,0,0"
            />
            <TextBlock
              Text="Preferred BPM"
              Foreground="#888888"
              FontSize="15"
              FontFamily="{StaticResource LexendDeca}"
              FontWeight="Bold"
              HorizontalAlignment="Right"
              Margin="0,0,30,0"
            />
          </Grid>

          <StackPanel x:Name="GenreRowsContainer" Margin="0,0,0,12">
            <Grid Margin="0,0,0,10">
              <Border
                Background="#222222"
                CornerRadius="4"
                Padding="12,8"
                HorizontalAlignment="Left"
                Width="140"
              >
                <TextBox
                  Text="{Binding GamingName, UpdateSourceTrigger=PropertyChanged}"
                  Style="{StaticResource InlineTextBox}"
                  Foreground="White"
                  FontSize="14"
                  FontFamily="{StaticResource LexendDeca}"
                />
              </Border>
              <StackPanel
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
              >
                <Button
                  Content="+"
                  Style="{StaticResource CircleBpmButton}"
                  Command="{Binding IncrementGamingBpmCommand}"
                />
                <TextBox
                  Text="{Binding GamingBpm, UpdateSourceTrigger=LostFocus}"
                  Style="{StaticResource InlineTextBox}"
                  Foreground="White"
                  FontSize="14"
                  MaxLength="3"
                  FontFamily="{StaticResource LexendDeca}"
                  Width="70"
                  TextAlignment="Center"
                  VerticalAlignment="Center"
                />
                <Button
                  Content="-"
                  Style="{StaticResource CircleBpmButton}"
                  Command="{Binding DecrementGamingBpmCommand}"
                  Margin="0,0,12,0"
                />
              </StackPanel>
            </Grid>

            <Grid Margin="0,0,0,10">
              <Border
                Background="#222222"
                CornerRadius="4"
                Padding="12,8"
                HorizontalAlignment="Left"
                Width="140"
              >
                <TextBox
                  Text="{Binding StudyingName, UpdateSourceTrigger=PropertyChanged}"
                  Style="{StaticResource InlineTextBox}"
                  Foreground="White"
                  FontSize="14"
                  FontFamily="{StaticResource LexendDeca}"
                />
              </Border>
              <StackPanel
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
              >
                <Button
                  Content="+"
                  Style="{StaticResource CircleBpmButton}"
                  Command="{Binding IncrementStudyingBpmCommand}"
                />

                <TextBox
                  Text="{Binding StudyingBpm, UpdateSourceTrigger=LostFocus}"
                  Style="{StaticResource InlineTextBox}"
                  Foreground="White"
                  FontSize="14"
                  MaxLength="3"
                  FontFamily="{StaticResource LexendDeca}"
                  Width="70"
                  TextAlignment="Center"
                  VerticalAlignment="Center"
                />

                <Button
                  Content="-"
                  Style="{StaticResource CircleBpmButton}"
                  Command="{Binding DecrementStudyingBpmCommand}"
                  Margin="0,0,12,0"
                />
              </StackPanel>
            </Grid>
          </StackPanel>

          <Button
            Content="+ Add More"
            Padding="0,10"
            Background="#222222"
            Foreground="#888888"
            BorderThickness="0"
            FontFamily="{StaticResource LexendDeca}"
            FontWeight="SemiBold"
            Cursor="Hand"
          >
            <Button.Resources>
              <Style TargetType="Button">
                <Setter Property="Template">
                  <Setter.Value>
                    <ControlTemplate TargetType="Button">
                      <Border Background="{TemplateBinding Background}" CornerRadius="4">
                        <ContentPresenter
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Margin="{TemplateBinding Padding}"
                        />
                      </Border>
                    </ControlTemplate>
                  </Setter.Value>
                </Setter>
              </Style>
            </Button.Resources>
          </Button>
        </StackPanel>
      </Grid>
    </Grid>

    <StackPanel
      x:Name="ToastContainer"
      VerticalAlignment="Bottom"
      HorizontalAlignment="Right"
      Margin="0,0,24,24"
      Panel.ZIndex="100"
    />
  </Grid>
</Window>
