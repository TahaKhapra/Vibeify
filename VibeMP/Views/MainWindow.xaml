                        <DataTrigger Binding="{Binding Playback.IsRepeatEnabled}" Value="True">
                          <Setter TargetName="IconPath" Property="Fill" Value="White" />
                        </DataTrigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Button.Template>
