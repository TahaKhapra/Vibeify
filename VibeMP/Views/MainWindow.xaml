                </Button>

                <Button
                  Command="{Binding ToggleRepeatCommand}"
                  Background="Transparent"
                  BorderThickness="0"
                  Width="32"
                  Height="32"
                  Margin="16,0,0,0"
                  Cursor="Hand"
                >
                  <Button.Template>
                    <ControlTemplate TargetType="Button">
                      <Border
                        x:Name="BgBorder"
