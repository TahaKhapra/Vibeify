<Window
  x:Class="VibeMP.Views.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:local="clr-namespace:VibeMP"
  xmlns:views="clr-namespace:VibeMP.Views"
  xmlns:vms="clr-namespace:VibeMP.ViewModels"
  xmlns:models="clr-namespace:VibeMP.Models"
  mc:Ignorable="d"
  Icon="/Resources/Assets/vibeify.ico"
  Title="Vibeify"
  Height="620"
  Width="950"
  Background="#181818"
  WindowStartupLocation="CenterScreen"
  AllowDrop="True"
  Drop="Window_Drop"
>
  <Window.DataContext>
    <vms:MainViewModel />
  </Window.DataContext>

  <WindowChrome.WindowChrome>
    <WindowChrome
      CaptionHeight="35"
      GlassFrameThickness="0"
      CornerRadius="0"
      UseAeroCaptionButtons="False"
    />
  </WindowChrome.WindowChrome>

  <Window.Resources>
    <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    <local:ShowPlayIconIfActive x:Key="ShowPlayIconIfActive" />
    <BooleanToVisibilityConverter x:Key="BoolToVis" />

    <Style x:Key="OnboardingVisibilityStyle" TargetType="FrameworkElement">
      <Setter Property="Visibility" Value="Collapsed" />
      <Style.Triggers>
        <DataTrigger
          Binding="{Binding CurrentViewState}"
          Value="{x:Static models:AppViewState.Onboarding}"
        >
          <Setter Property="Visibility" Value="Visible" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="BpmFixerVisibilityStyle" TargetType="FrameworkElement">
      <Setter Property="Visibility" Value="Collapsed" />
      <Style.Triggers>
        <DataTrigger
          Binding="{Binding CurrentViewState}"
          Value="{x:Static models:AppViewState.BpmFixer}"
        >
          <Setter Property="Visibility" Value="Visible" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="DashboardVisibilityStyle" TargetType="FrameworkElement">
      <Setter Property="Visibility" Value="Collapsed" />
      <Style.Triggers>
        <DataTrigger
          Binding="{Binding CurrentViewState}"
          Value="{x:Static models:AppViewState.Dashboard}"
        >
          <Setter Property="Visibility" Value="Visible" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style TargetType="ScrollBar">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ScrollBar">
            <Grid x:Name="Bg" SnapsToDevicePixels="true" Background="Transparent">
              <Border Padding="0,4">
                <Track x:Name="PART_Track" IsDirectionReversed="true">
                  <Track.Thumb>
                    <Thumb>
                      <Thumb.Template>
                        <ControlTemplate TargetType="Thumb">
                          <Grid Background="Transparent">
                            <Border
                              x:Name="ThumbVisual"
                              Background="#4A4A4A"
                              CornerRadius="3"
                              MinHeight="30"
                              Width="4"
                              Margin="0,2"
                              HorizontalAlignment="Center"
                            />
                          </Grid>
                          <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                              <Setter TargetName="ThumbVisual" Property="Width" Value="8" />
                              <Setter
                                TargetName="ThumbVisual"
                                Property="Background"
                                Value="#6A6A6A"
                              />
                            </Trigger>
                          </ControlTemplate.Triggers>
                        </ControlTemplate>
                      </Thumb.Template>
                    </Thumb>
                  </Track.Thumb>
                </Track>
              </Border>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>

      <Style.Triggers>
        <Trigger Property="Orientation" Value="Vertical">
          <Setter Property="Width" Value="10" />
        </Trigger>
        <Trigger Property="Orientation" Value="Horizontal">
          <Setter Property="Height" Value="10" />
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="ScrollBar">
                <Grid x:Name="Bg" SnapsToDevicePixels="true" Background="Transparent">
                  <Border Padding="4,0">
                    <Track x:Name="PART_Track" IsDirectionReversed="false">
                      <Track.Thumb>
                        <Thumb>
                          <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                              <Grid Background="Transparent">
                                <Border
                                  x:Name="ThumbVisual"
                                  Background="#4A4A4A"
                                  CornerRadius="3"
                                  MinWidth="30"
                                  Height="4"
                                  Margin="2,0"
                                  VerticalAlignment="Center"
                                />
                              </Grid>
                              <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                  <Setter TargetName="ThumbVisual" Property="Height" Value="8" />
                                  <Setter
                                    TargetName="ThumbVisual"
                                    Property="Background"
                                    Value="#6A6A6A"
                                  />
                                </Trigger>
                              </ControlTemplate.Triggers>
                            </ControlTemplate>
                          </Thumb.Template>
                        </Thumb>
                      </Track.Thumb>
                    </Track>
                  </Border>
                </Grid>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Trigger>
      </Style.Triggers>
    </Style>

    <DataTemplate DataType="{x:Type models:NotificationToast}">
      <Border
        Background="#2D2D2D"
        BorderBrush="#FF4B4B"
        BorderThickness="1,0,0,0"
        CornerRadius="4"
        Width="280"
        Height="65"
        Padding="12,8"
      >
        <StackPanel>
          <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="Bold" FontSize="13" />
          <TextBlock
            Text="{Binding Message}"
            Foreground="DarkGray"
            FontSize="11"
            Margin="0,2,0,0"
          />
        </StackPanel>
      </Border>
    </DataTemplate>
  </Window.Resources>

  <Grid>
    <Grid.Style>
      <Style TargetType="Grid">
        <Setter Property="Margin" Value="0" />
        <Style.Triggers>
          <DataTrigger
            Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}"
            Value="Maximized"
          >
            <Setter Property="Margin" Value="8" />
          </DataTrigger>
        </Style.Triggers>
      </Style>
    </Grid.Style>

    <Grid.RowDefinitions>
      <RowDefinition Height="35" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Background="#282828" Panel.ZIndex="1000">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <StackPanel
        Grid.Column="0"
        Orientation="Horizontal"
        VerticalAlignment="Center"
        Margin="16,0,0,0"
      >
        <Viewbox Width="20" Height="16" Margin="0,0,8,0">
          <Canvas Width="130" Height="103">
            <Path
              Fill="White"
              Data="M81.2334 0C108.149 0.000156743 129.973 21.8251 129.973 48.7402V86.6484C129.973 95.6382 122.716 102.895 113.727 102.896H97.4795V59.5713H119.142V48.7402C119.142 27.7822 102.191 10.8312 81.2334 10.8311C60.2753 10.8311 46.0322 27.7821 46.0322 48.7402V81.2334L46.0234 81.7412C45.6453 92.4003 33.4611 102.896 21.6621 102.896C9.67583 102.895 0.000151912 93.2196 0 81.2334C0 69.247 9.67574 59.5713 21.6621 59.5713C23.5921 59.5713 28.8905 59.5724 32.4932 60.7783V48.7402C32.4932 21.825 54.3182 0 81.2334 0ZM108.311 92.0645H113.727C116.705 92.0643 119.142 89.6269 119.142 86.6484V70.4023H108.311V92.0645ZM21.6621 74.0127C17.6907 74.0127 14.4414 77.262 14.4414 81.2334C14.4416 85.2046 17.6908 88.4541 21.6621 88.4541C25.6334 88.4541 28.8827 85.2047 28.8828 81.2334C28.8828 77.262 25.6335 74.0127 21.6621 74.0127Z M86.6484 97.4795H81.2334V59.5713H86.6484V97.4795Z M73.1094 92.0645H67.6943V64.9863H73.1094V92.0645Z M59.5713 62.2783V83.9404H54.1553V62.2783H59.5713Z"
            />
          </Canvas>
        </Viewbox>
        <TextBlock
          Text="Vibeify"
          Foreground="White"
          FontSize="12"
          FontWeight="Bold"
          VerticalAlignment="Center"
        />
      </StackPanel>

      <StackPanel
        Grid.Column="2"
        Orientation="Horizontal"
        WindowChrome.IsHitTestVisibleInChrome="True"
      >
        <StackPanel.Resources>
          <Style TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="46" />
            <Setter Property="Template">
              <Setter.Value>
                <ControlTemplate TargetType="Button">
                  <Border Background="{TemplateBinding Background}">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter Property="Background" Value="#3F3F3F" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Setter.Value>
            </Setter>
          </Style>
        </StackPanel.Resources>

        <Button Click="Minimize_Click">
          <Path
            Data="M0,5 L10,5 L10,6 L0,6 Z"
            Fill="White"
            Width="10"
            Height="10"
            Stretch="None"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Margin="0,5,0,0"
          />
        </Button>
        <Button Click="Maximize_Click">
          <Path
            Data="M1,1 L9,1 L9,9 L1,9 Z"
            Stroke="White"
            StrokeThickness="1"
            Width="10"
            Height="10"
            Stretch="None"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
          />
        </Button>
        <Button Click="Close_Click">
          <Button.Style>
            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
              <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter Property="Background" Value="#E81123" />
                </Trigger>
              </Style.Triggers>
            </Style>
          </Button.Style>
          <Path
            Data="M1,1 L9,9 M1,9 L9,1"
            Stroke="White"
            StrokeThickness="1.2"
            Width="10"
            Height="10"
            Stretch="None"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
          />
        </Button>
      </StackPanel>
    </Grid>

    <Grid Grid.Row="1">
      <Grid>
        <Grid.Style>
          <Style TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger
                Binding="{Binding CurrentViewState}"
                Value="{x:Static models:AppViewState.Settings}"
              >
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Grid.Style>

        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel
          Grid.Row="0"
          Orientation="Horizontal"
          HorizontalAlignment="Center"
          Margin="0,40,0,0"
        >
          <Viewbox Width="54" Height="42" Margin="0,0,16,0">
            <Canvas Width="130" Height="103">
              <Path
                Fill="White"
                Data="M81.2334 0C108.149 0.000156743 129.973 21.8251 129.973 48.7402V86.6484C129.973 95.6382 122.716 102.895 113.727 102.896H97.4795V59.5713H119.142V48.7402C119.142 27.7822 102.191 10.8312 81.2334 10.8311C60.2753 10.8311 46.0322 27.7821 46.0322 48.7402V81.2334L46.0234 81.7412C45.6453 92.4003 33.4611 102.896 21.6621 102.896C9.67583 102.895 0.000151912 93.2196 0 81.2334C0 69.247 9.67574 59.5713 21.6621 59.5713C23.5921 59.5713 28.8905 59.5724 32.4932 60.7783V48.7402C32.4932 21.825 54.3182 0 81.2334 0ZM108.311 92.0645H113.727C116.705 92.0643 119.142 89.6269 119.142 86.6484V70.4023H108.311V92.0645ZM21.6621 74.0127C17.6907 74.0127 14.4414 77.262 14.4414 81.2334C14.4416 85.2046 17.6908 88.4541 21.6621 88.4541C25.6334 88.4541 28.8827 85.2047 28.8828 81.2334C28.8828 77.262 25.6335 74.0127 21.6621 74.0127Z M86.6484 97.4795H81.2334V59.5713H86.6484V97.4795Z M73.1094 92.0645H67.6943V64.9863H73.1094V92.0645Z M59.5713 62.2783V83.9404H54.1553V62.2783H59.5713Z"
              />
            </Canvas>
          </Viewbox>
          <TextBlock
            Text="Vibeify"
            Foreground="White"
            FontSize="36"
            FontWeight="Bold"
            VerticalAlignment="Center"
          />
        </StackPanel>

        <Grid
          Grid.Row="1"
          HorizontalAlignment="Center"
          VerticalAlignment="Top"
          Margin="0,30,0,0"
          Width="760"
        >
          <Grid.RowDefinitions>
            <RowDefinition Height="300" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340" />
            <ColumnDefinition Width="80" />
            <ColumnDefinition Width="340" />
          </Grid.ColumnDefinitions>

          <views:ImportDropZone Grid.Row="0" Grid.Column="0" />

          <views:CategoryEditor Grid.Row="0" Grid.Column="2" />

          <Button
            Grid.Row="1"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            Command="{Binding CloseSettingsCommand}"
            Content="Save &amp; Return"
            Padding="0,14"
            Margin="0,30,0,0"
            Foreground="Black"
            BorderThickness="0"
            FontWeight="SemiBold"
            Cursor="Hand"
          >
            <Button.Style>
              <Style TargetType="Button">
                <Setter Property="Background" Value="White" />
                <Setter Property="Template">
                  <Setter.Value>
                    <ControlTemplate TargetType="Button">
                      <Border
                        x:Name="ButtonBorder"
                        Background="{TemplateBinding Background}"
                        CornerRadius="6"
                      >
                        <ContentPresenter
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Margin="{TemplateBinding Padding}"
                        />
                      </Border>
                      <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter TargetName="ButtonBorder" Property="Background" Value="#EEEEEE" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                          <Setter TargetName="ButtonBorder" Property="Background" Value="#333333" />
                          <Setter Property="Foreground" Value="#666666" />
                        </Trigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Setter.Value>
                </Setter>
              </Style>
            </Button.Style>
          </Button>
        </Grid>
      </Grid>

      <Grid Style="{StaticResource DashboardVisibilityStyle}">
        <Grid.RowDefinitions>
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="240" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
          Grid.Row="0"
          Grid.Column="0"
          Background="#181818"
          BorderBrush="#282828"
          BorderThickness="0,0,1,0"
          Padding="16,24,16,16"
        >
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Button
              Grid.Row="0"
              Command="{Binding SelectHomeCommand}"
              Background="Transparent"
              BorderThickness="0"
              Margin="0,0,0,16"
              Cursor="Hand"
            >
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="12,8">
                    <StackPanel Orientation="Horizontal">
                      <Path
                        Data="M1 6V15H6V11C6 9.89543 6.89543 9 8 9C9.10457 9 10 9.89543 10 11V15H15V6L8 0L1 6Z"
                        Fill="White"
                        Width="15"
                        Height="15"
                        Margin="0,0,12,0"
                        Stretch="Fill"
                        VerticalAlignment="Center"
                      />
                      <TextBlock
                        Text="Home"
                        Foreground="White"
                        FontSize="15"
                        FontWeight="Bold"
                        VerticalAlignment="Center"
                      />
                    </StackPanel>
                  </Border>
                  <ControlTemplate.Triggers>
                    <DataTrigger Binding="{Binding IsHomeSelected}" Value="True">
                      <Setter Property="Background" Value="#282828" />
                    </DataTrigger>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter Property="Background" Value="#1A1A1A" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>

            <TextBlock
              Grid.Row="1"
              Text="Your Library"
              Foreground="#A7A7A7"
              FontSize="12"
              FontWeight="Bold"
              Margin="8,0,0,16"
            />

            <ScrollViewer
              Grid.Row="2"
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled"
              Margin="0,0,0,16"
            >
              <ListBox
                ItemsSource="{Binding Categories}"
                SelectedItem="{Binding SelectedCategory}"
                Background="Transparent"
                BorderThickness="0"
              >
                <ListBox.Resources>
                  <SolidColorBrush
                    x:Key="{x:Static SystemColors.HighlightBrushKey}"
                    Color="#282828"
                  />
                  <SolidColorBrush
                    x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
                    Color="#1A1A1A"
                  />
                </ListBox.Resources>
                <ListBox.ItemContainerStyle>
                  <Style TargetType="ListBoxItem">
                    <Setter Property="Template">
                      <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                          <Border
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="12,8"
                            Margin="0,2"
                          >
                            <ContentPresenter />
                          </Border>
                        </ControlTemplate>
                      </Setter.Value>
                    </Setter>
                  </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <Grid Background="Transparent" Cursor="Hand">
                      <Grid.InputBindings>
                        <MouseBinding
                          Gesture="LeftClick"
                          Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                          CommandParameter="{Binding}"
                        />
                      </Grid.InputBindings>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <Path
                        Grid.Column="0"
                        Data="M12,10 A2,2 0 1,1 12,14 A2,2 0 1,1 12,10 M18,7 A2,2 0 1,1 18,11 A2,2 0 1,1 18,7 M15.318 3.631C14.291 3.224 13.172 3 12 3C7.029 3 3 7.029 3 12C3 16.971 7.029 21 12 21C16.151 21 19.646 18.189 20.686 14.367 M20 9V2L22 4"
                        Stroke="White"
                        StrokeThickness="1.5"
                        StrokeStartLineCap="Round"
                        StrokeEndLineCap="Round"
                        StrokeLineJoin="Round"
                        Fill="Transparent"
                        Width="16"
                        Height="16"
                        Margin="0,0,12,0"
                        Stretch="Uniform"
                        VerticalAlignment="Center"
                      />
                      <TextBlock
                        Grid.Column="1"
                        Text="{Binding Name}"
                        Foreground="White"
                        FontSize="14"
                        FontWeight="SemiBold"
                        VerticalAlignment="Center"
                        TextTrimming="CharacterEllipsis"
                      />
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </ScrollViewer>

            <Button
              Grid.Row="3"
              Command="{Binding OpenSettingsCommand}"
              Background="Transparent"
              BorderThickness="0"
              Cursor="Hand"
            >
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border
                    x:Name="SettingsBorder"
                    Background="{TemplateBinding Background}"
                    CornerRadius="4"
                    Padding="12,8"
                  >
                    <StackPanel Orientation="Horizontal">
                      <Path
                        x:Name="SettingsIcon"
                        Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6 s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z"
                        Fill="White"
                        Width="16"
                        Height="16"
                        Margin="0,0,12,0"
                        Stretch="Fill"
                        VerticalAlignment="Center"
                      />
                      <TextBlock
                        Text="Settings"
                        Foreground="White"
                        FontSize="14"
                        FontWeight="SemiBold"
                        VerticalAlignment="Center"
                      />
                    </StackPanel>
                  </Border>
                  <ControlTemplate.Triggers>
                    <DataTrigger
                      Binding="{Binding CurrentViewState}"
                      Value="{x:Static models:AppViewState.Settings}"
                    >
                      <Setter TargetName="SettingsBorder" Property="Background" Value="#282828" />
                      <Setter TargetName="SettingsIcon" Property="Fill" Value="White" />
                    </DataTrigger>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter TargetName="SettingsBorder" Property="Background" Value="#1A1A1A" />
                      <Setter TargetName="SettingsIcon" Property="Fill" Value="White" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>
          </Grid>
        </Border>

        <Grid Grid.Row="0" Grid.Column="1" Margin="16,24,24,16">
          <Grid>
            <Grid.Style>
              <Style TargetType="Grid">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsHomeSelected}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Grid.Style>

            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="8,0,0,24">
              <TextBlock
                Text="{Binding SelectedCategory.Name, TargetNullValue='Select a category'}"
                Foreground="White"
                FontSize="32"
                FontWeight="Bold"
                Margin="0,0,0,4"
              />
              <StackPanel
                Orientation="Horizontal"
                Visibility="{Binding SelectedCategory, Converter={StaticResource BoolToVis}}"
              >
                <TextBlock
                  Text="{Binding SelectedCategory.TargetBpm, StringFormat='~ {0} BPM'}"
