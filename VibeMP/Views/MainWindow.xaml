                                        Width="28"
                                        Height="28"
                                        CornerRadius="14"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,8,20"
                                        Panel.ZIndex="3"
                                      >
                                        <Border.Visibility>
                                          <MultiBinding Converter="{StaticResource ShowPlayIconIfActive}">
                                            <Binding />
                                            <Binding
                                              Path="DataContext.Playback.SelectedTrack"
                                              RelativeSource="{RelativeSource AncestorType=Window}"
                                            />
                                          </MultiBinding>
                                        </Border.Visibility>

                                        <Path
                                          x:Name="IndicatorIcon"
                                          Data="M14,19H18V5H14M6,19H10V5H6V19Z"
                                          Fill="Black"
                                          Width="10"
                                          Height="10"
                                          Stretch="Fill"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                        />
                                      </Border>
                                    </Grid>

                                    <TextBlock
                                      Text="{Binding Title}"
                                      Foreground="White"
                                      FontWeight="Bold"
                                      FontSize="13"
                                      TextTrimming="CharacterEllipsis"
                                      Margin="0,0,0,4"
                                    />

                                    <Grid>
                                      <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                      </Grid.ColumnDefinitions>
                                      <TextBlock
                                        Grid.Column="0"
                                        Text="{Binding Artist}"
                                        Foreground="#A7A7A7"
                                        FontSize="11"
                                        TextTrimming="CharacterEllipsis"
                                        Margin="0,0,8,0"
                                      />
                                      <TextBlock
                                        Grid.Column="1"
                                        Text="{Binding Bpm, StringFormat='{}{0:F0} BPM'}"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        FontSize="10"
                                        VerticalAlignment="Center"
                                      />
                                    </Grid>
                                  </StackPanel>

                                  <DataTemplate.Triggers>
                                    <DataTrigger
                                      Binding="{Binding DataContext.Playback.IsPlaying, RelativeSource={RelativeSource AncestorType=Window}}"
                                      Value="False"
                                    >
                                      <Setter
                                        TargetName="IndicatorIcon"
                                        Property="Data"
                                        Value="M8,5.14V19.14L19,12.14L8,5.14Z"
                                      />
                                      <Setter
                                        TargetName="IndicatorIcon"
                                        Property="Margin"
                                        Value="2,0,0,0"
                                      />
                                    </DataTrigger>
                                  </DataTemplate.Triggers>
                                </DataTemplate>
                              </ListBox.ItemTemplate>
                            </ListBox>
                          </ScrollViewer>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </ScrollViewer>
          </Grid>
        </Grid>

        <Border
          Grid.Row="1"
          Grid.Column="0"
          Grid.ColumnSpan="2"
          Background="#181818"
          BorderBrush="#282828"
          BorderThickness="0,1,0,0"
          Padding="16"
        >
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="260" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="220" />
