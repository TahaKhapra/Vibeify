                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                  Grid.Column="0"
                  Text="{Binding Playback.PlaybackPositionString, TargetNullValue=''}"
                  Foreground="#A7A7A7"
                  FontSize="11"
                  Margin="0,0,8,0"
                  VerticalAlignment="Center"
                />

                <Slider
                  Grid.Column="1"
                  Value="{Binding Playback.PlaybackProgressSeconds, Mode=OneWay}"
                  Maximum="{Binding Playback.PlaybackDurationSeconds, Mode=OneWay}"
                  VerticalAlignment="Center"
                  Focusable="False"
                  IsMoveToPointEnabled="True"
                  PreviewMouseLeftButtonDown="ProgressBar_PreviewMouseLeftButtonDown"
                  PreviewMouseLeftButtonUp="ProgressBar_PreviewMouseLeftButtonUp"
                  Visibility="{Binding Playback.SelectedTrack, Converter={StaticResource NullToVisibilityConverter}}"
                >
                  <Slider.Style>
                    <Style TargetType="Slider">
                      <Setter Property="Template">
                        <Setter.Value>
                          <ControlTemplate TargetType="Slider">
                            <Grid VerticalAlignment="Center" Background="Transparent" Height="16">
                              <Border
                                Background="#282828"
                                Height="4"
                                CornerRadius="2"
                                VerticalAlignment="Center"
                                SnapsToDevicePixels="True"
                              />

                              <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                  <RepeatButton Command="{x:Null}" IsHitTestVisible="False">
                                    <RepeatButton.Template>
                                      <ControlTemplate TargetType="RepeatButton">
                                        <Border
                                          Background="White"
                                          Height="4"
                                          CornerRadius="2"
                                          Margin="0,0,-14,0"
                                          SnapsToDevicePixels="True"
                                        />
                                      </ControlTemplate>
                                    </RepeatButton.Template>
                                  </RepeatButton>
                                </Track.DecreaseRepeatButton>

