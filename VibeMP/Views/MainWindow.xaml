                            Fill="#181818"
                            Width="16"
                            Height="16"
                            Stretch="Fill"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Panel.ZIndex="0"
                          />

                          <Image
                            Source="{Binding AlbumArt, FallbackValue={x:Null}, TargetNullValue={x:Null}}"
                            Stretch="UniformToFill"
                            RenderOptions.BitmapScalingMode="HighQuality"
