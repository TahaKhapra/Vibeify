                            <Path
                              Data="M8,5.14V19.14L19,12.14L8,5.14Z"
                              Fill="White"
                              Width="14"
                              Height="14"
                              Stretch="Fill"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                            />
                          </Border>
                        </Grid>
                        <StackPanel VerticalAlignment="Center">
                          <TextBlock
                            Text="{Binding Title}"
