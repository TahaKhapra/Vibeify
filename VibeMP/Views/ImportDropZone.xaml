<UserControl
  x:Class="VibeMP.Views.ImportDropZone"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Background="Transparent"
>
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
  </UserControl.Resources>

  <Grid>
    <Grid>
      <Grid.Style>
        <Style TargetType="Grid">
          <Setter Property="Visibility" Value="Collapsed" />
          <Style.Triggers>
            <DataTrigger Binding="{Binding Importer.PendingImportPaths.Count}" Value="0">
              <Setter Property="Visibility" Value="Visible" />
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Grid.Style>

      <Rectangle
        Stroke="#333333"
        StrokeThickness="2"
        StrokeDashArray="4 4"
        RadiusX="12"
        RadiusY="12"
        Fill="#1C1C1C"
      />

      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
        <Path
          Data="M4 4H10L12 6H20V18H4V4Z"
          Stroke="#555555"
          StrokeThickness="2"
          Fill="Transparent"
          Width="42"
          Height="36"
          Stretch="Fill"
          Margin="0,0,0,16"
          HorizontalAlignment="Center"
        />
        <TextBlock
          Text="Drag and drop your music here"
          TextAlignment="Center"
          Foreground="#777777"
          FontSize="15"
          FontWeight="Medium"
          LineHeight="22"
        />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
          <Button Command="{Binding AddFolderCommand}" Cursor="Hand" Margin="0,0,12,0">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border
                  Background="#252525"
                  CornerRadius="6"
                  Padding="16,8"
                  BorderBrush="#333333"
                  BorderThickness="1"
                >
                  <TextBlock Text="Select Folder" Foreground="White" FontWeight="SemiBold" />
                </Border>
              </ControlTemplate>
            </Button.Template>
          </Button>

          <Button Command="{Binding AddFilesCommand}" Cursor="Hand">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border
                  Background="#252525"
                  CornerRadius="6"
                  Padding="16,8"
                  BorderBrush="#333333"
                  BorderThickness="1"
                >
                  <TextBlock Text="Select Files" Foreground="White" FontWeight="SemiBold" />
                </Border>
              </ControlTemplate>
            </Button.Template>
          </Button>
        </StackPanel>

        <TextBlock
          Text="{Binding Importer.StatusText}"
          Foreground="#666666"
          FontWeight="Bold"
          FontSize="11"
          Margin="0,16,0,4"
          MaxWidth="260"
          TextTrimming="CharacterEllipsis"
          HorizontalAlignment="Center"
        />

        <ProgressBar
          Value="{Binding Importer.ScanProgressValue}"
          Maximum="{Binding Importer.ScanProgressMax}"
          Width="220"
          Height="4"
          Background="#111111"
          Foreground="#888888"
          Visibility="{Binding Importer.IsProcessing, Converter={StaticResource BoolToVis}}"
        />
      </StackPanel>
    </Grid>

    <Grid>
      <Grid.Style>
        <Style TargetType="Grid">
          <Setter Property="Visibility" Value="Visible" />
          <Style.Triggers>
            <DataTrigger Binding="{Binding Importer.PendingImportPaths.Count}" Value="0">
              <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Grid.Style>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0" Margin="0,0,0,10">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="10" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Button
          Grid.Column="0"
          Command="{Binding AddFolderCommand}"
          HorizontalContentAlignment="Stretch"
          Cursor="Hand"
        >
          <Button.Template>
            <ControlTemplate TargetType="Button">
              <Border
                Background="#1C1C1C"
                BorderBrush="#333333"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10,8"
              >
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                  <TextBlock
                    Text="+"
                    Foreground="#FFFFFF"
                    FontWeight="Bold"
                    FontSize="14"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                  />
                  <TextBlock
                    Text="Add Folder"
                    Foreground="#999999"
                    FontSize="12"
                    VerticalAlignment="Center"
                  />
                </StackPanel>
              </Border>
            </ControlTemplate>
          </Button.Template>
        </Button>

        <Button
          Grid.Column="2"
          Command="{Binding AddFilesCommand}"
          HorizontalContentAlignment="Stretch"
          Cursor="Hand"
        >
          <Button.Template>
            <ControlTemplate TargetType="Button">
              <Border
                Background="#1C1C1C"
                BorderBrush="#333333"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10,8"
              >
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                  <TextBlock
                    Text="+"
                    Foreground="#FFFFFF"
                    FontWeight="Bold"
                    FontSize="14"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                  />
                  <TextBlock
                    Text="Add Files"
                    Foreground="#999999"
                    FontSize="12"
                    VerticalAlignment="Center"
                  />
                </StackPanel>
              </Border>
            </ControlTemplate>
          </Button.Template>
        </Button>
      </Grid>

      <Border
        Grid.Row="1"
        Background="#141414"
        CornerRadius="6"
        BorderBrush="#222222"
        BorderThickness="1"
      >
        <ListBox
          ItemsSource="{Binding Importer.PendingImportPaths}"
          Background="Transparent"
          BorderThickness="0"
          Padding="5"
          HorizontalContentAlignment="Stretch"
          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
        >
          <ListBox.Resources>
            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#252525" />
            <SolidColorBrush
              x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
              Color="#1A1A1A"
            />
          </ListBox.Resources>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Grid Margin="4,3">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Path
                  Grid.Row="0"
                  Grid.Column="0"
                  Data="M21,3V15.5A3.5,3.5 0 0,1 17.5,19A3.5,3.5 0 0,1 14,15.5A3.5,3.5 0 0,1 17.5,12C18.04,12 18.55,12.12 19,12.34V6.47L9,8.6V17.5A3.5,3.5 0 0,1 5.5,21A3.5,3.5 0 0,1 2,17.5A3.5,3.5 0 0,1 5.5,14C6.04,14 6.55,14.12 7,14.34V6L21,3Z"
                  Fill="#FFFFFF"
                  Width="12"
                  Height="12"
                  Margin="0,0,8,0"
                  Stretch="Fill"
                  VerticalAlignment="Center"
                />
                <TextBlock
                  Grid.Row="0"
                  Grid.Column="1"
                  Text="{Binding DisplayName}"
                  Foreground="#CCCCCC"
                  FontSize="11"
                  TextTrimming="CharacterEllipsis"
                  ToolTip="{Binding FullPath}"
                />
                <ProgressBar
                  Grid.Row="1"
                  Grid.Column="1"
                  Value="{Binding ProgressPercent}"
                  Maximum="100"
                  Height="2"
                  Margin="0,4,0,2"
                  Background="#282828"
                  Foreground="White"
                  BorderThickness="0"
                />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>
    </Grid>
  </Grid>
</UserControl>
