<UserControl
  x:Class="VibeMP.Views.CategoryEditor"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:VibeMP"
  Background="Transparent"
>
  <UserControl.Resources>
    <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />

    <Style x:Key="CircleBpmButton" TargetType="Button">
      <Setter Property="Background" Value="#2D2D2D" />
      <Setter Property="Foreground" Value="#AAAAAA" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Width" Value="24" />
      <Setter Property="Height" Value="24" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="12">
              <Grid>
                <Viewbox
                  MaxWidth="18"
                  MaxHeight="18"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                >
                  <TextBlock
                    Text="{TemplateBinding Content}"
                    Foreground="{TemplateBinding Foreground}"
                    FontWeight="{TemplateBinding FontWeight}"
                    TextAlignment="Center"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                  />
                </Viewbox>
              </Grid>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="InlineTextBox" TargetType="TextBox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CaretBrush" Value="White" />
      <Setter Property="SelectionBrush" Value="#555555" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="Validation.ErrorTemplate" Value="{x:Null}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border Background="{TemplateBinding Background}">
              <ScrollViewer x:Name="PART_ContentHost" Focusable="false" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="140" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <TextBlock
        Grid.Column="0"
        Text="Categories"
        Foreground="#888888"
        FontSize="15"
        FontWeight="Bold"
        HorizontalAlignment="Left"
        VerticalAlignment="Center"
        Margin="4,0,0,0"
      />
      <TextBlock
        Grid.Column="1"
        Text="Target BPM"
        Foreground="#888888"
        FontSize="15"
        FontWeight="Bold"
        HorizontalAlignment="Right"
        VerticalAlignment="Center"
        Margin="0,0,32,0"
      />
    </Grid>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <ItemsControl ItemsSource="{Binding Categories}" Margin="0,0,0,10">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Grid Margin="0,0,0,4">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="140" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border
                  Grid.Row="0"
                  Grid.Column="0"
                  Background="#222222"
                  CornerRadius="4"
                  Padding="12,8"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Left"
                  Width="140"
                >
                  <TextBox
                    Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                    Style="{StaticResource InlineTextBox}"
                    Foreground="White"
                    FontSize="14"
                    VerticalAlignment="Center"
                  />
                </Border>

                <StackPanel
                  Grid.Row="0"
                  Grid.Column="2"
                  Orientation="Horizontal"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Right"
                >
                  <Button
                    Content="+"
                    Style="{StaticResource CircleBpmButton}"
                    Command="{Binding DataContext.IncrementBpmCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                    CommandParameter="{Binding}"
                    VerticalAlignment="Center"
                  />

                  <TextBox
                    Text="{Binding TargetBpm, Mode=OneWay}"
                    TextChanged="CategoryBpmInput_TextChanged"
                    Foreground="White"
                    Background="Transparent"
                    BorderThickness="0"
                    FontSize="14"
                    Width="36"
                    TextAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="6,0"
                    Padding="0"
                    Focusable="True"
                  />

                  <Button
                    Content="-"
                    Style="{StaticResource CircleBpmButton}"
                    Command="{Binding DataContext.DecrementBpmCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                    CommandParameter="{Binding}"
                    VerticalAlignment="Center"
                  />

                  <Button
                    Background="Transparent"
                    BorderThickness="0"
                    Margin="10,0,0,0"
                    Padding="0"
                    Cursor="Hand"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Command="{Binding DataContext.DeleteCategoryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                    CommandParameter="{Binding}"
                    ToolTip="Delete category"
                  >
                    <Button.Template>
                      <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                          <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                          />
                        </Border>
                      </ControlTemplate>
                    </Button.Template>

                    <Path
                      Data="M10,12 V17 M14,12 V17 M4,7 H20 M6,10 V18 C6,19.6569 7.34315,21 9,21 H15 C16.6569,21 18,19.6569 18,18 V10 M9,5 C9,3.89543 9.89543,3 11,3 H13 C14.1046,3 15,3.89543 15,5 V7 H9 V5 Z"
                      Stroke="Red"
                      StrokeThickness="1.5"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      StrokeLineJoin="Round"
                      Fill="Transparent"
                      Width="16"
                      Height="16"
                      Stretch="Fill"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                    />
                  </Button>
                </StackPanel>

                <TextBlock
                  Grid.Row="1"
                  Grid.Column="0"
                  Grid.ColumnSpan="3"
                  Text="{Binding RowErrorMessage}"
                  Foreground="Red"
                  FontSize="10"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Top"
                  Margin="4,4,4,4"
                  TextWrapping="Wrap"
                  Visibility="{Binding RowErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"
                />
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Command="{Binding AddCategoryCommand}" Cursor="Hand" Height="42" Margin="0,4,0,10">
          <Button.Template>
            <ControlTemplate TargetType="Button">
              <Grid>
                <Rectangle
                  Stroke="#333333"
                  StrokeThickness="1.5"
                  StrokeDashArray="4 4"
                  RadiusX="6"
                  RadiusY="6"
                  Fill="#1C1C1C"
                />
                <StackPanel
                  Orientation="Horizontal"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                >
                  <TextBlock
                    Text="+"
                    Foreground="#777777"
                    FontWeight="Bold"
                    FontSize="16"
                    Margin="0,0,8,1"
                    VerticalAlignment="Center"
                  />
                  <TextBlock
                    Text="Add custom category"
                    Foreground="#777777"
                    FontSize="13"
                    FontWeight="Medium"
                    VerticalAlignment="Center"
                  />
                </StackPanel>
              </Grid>
            </ControlTemplate>
          </Button.Template>
        </Button>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
