<Application x:Class="VibeMP.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:VibeMP"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Material.Icons.WPF;component/Resources/Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <FontFamily x:Key="LexendDeca">pack://application:,,,/Resources/Fonts/#Lexend Deca</FontFamily>
        </ResourceDictionary>
    </Application.Resources>
</Application>